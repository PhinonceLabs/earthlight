# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/projects
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/projects

# Neon Postgres / Drizzle
# Runtime uses Neon's pooled serverless connection string for local development and Vercel.
DATABASE_URL=
# Drizzle migrations prefer an unpooled connection to avoid PgBouncer/DDL fragility.
# Vercel's Neon integration may provide DATABASE_URL_UNPOOLED automatically; set this
# only when you want an explicit migration-only URL instead.
DATABASE_MIGRATION_URL=
